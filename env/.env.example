# WaggleBot 환경 변수 — cp .env.example .env 후 실제 값 입력
DATABASE_URL=mysql+pymysql://wagglebot:wagglebot@db/wagglebot
MARIADB_ROOT_PASSWORD=
MARIADB_PASSWORD=

# LLM (Claude CLI bridge)
LLM_WORKER_URL=http://llm-worker:8090
LLM_MODEL=haiku
CLAUDE_HOST_CONFIG_DIR=/home/justant/.claude

# TTS
TTS_ENGINE=fish-speech
FISH_SPEECH_URL=http://fish-speech:8080

# 크롤러
CRAWL_INTERVAL_HOURS=1

# 비디오
VIDEO_GEN_ENABLED=false

# 텔레그램 브리지 (telegram-bridge 서비스 전용)
TELEGRAM_BOT_TOKEN=
ALLOWED_USER_IDS=
ANTHROPIC_API_KEY=
GITHUB_TOKEN=
LOG_LEVEL=info
HOOKS_PORT=3847
