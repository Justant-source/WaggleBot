{
  "_version": "2.0",
  "_description": "WaggleBot 쇼츠 화면 구성 정책. 이 파일만 수정하면 연출이 바뀐다. 모든 에셋은 폴더 단위로 관리하며 런타임에 랜덤 선택.",

  "moods": {
    "touching": {
      "label": "감동",
      "intro_image_dir": "assets/image/intro/mood/touching",
      "outro_image_dir": "assets/image/outro/mood/touching",
      "bgm_dir": "assets/bgm/mood/touching",
      "tts_emotion": "gentle"
    },
    "humor": {
      "label": "유머",
      "intro_image_dir": "assets/image/intro/mood/humor",
      "outro_image_dir": "assets/image/outro/mood/humor",
      "bgm_dir": "assets/bgm/mood/humor",
      "tts_emotion": "cheerful"
    },
    "anger": {
      "label": "분노",
      "intro_image_dir": "assets/image/intro/mood/anger",
      "outro_image_dir": "assets/image/outro/mood/anger",
      "bgm_dir": "assets/bgm/mood/anger",
      "tts_emotion": "serious"
    },
    "sadness": {
      "label": "슬픔",
      "intro_image_dir": "assets/image/intro/mood/sadness",
      "outro_image_dir": "assets/image/outro/mood/sadness",
      "bgm_dir": "assets/bgm/mood/sadness",
      "tts_emotion": "sad"
    },
    "horror": {
      "label": "공포",
      "intro_image_dir": "assets/image/intro/mood/horror",
      "outro_image_dir": "assets/image/outro/mood/horror",
      "bgm_dir": "assets/bgm/mood/horror",
      "tts_emotion": "whispering"
    },
    "info": {
      "label": "정보",
      "intro_image_dir": "assets/image/intro/mood/info",
      "outro_image_dir": "assets/image/outro/mood/info",
      "bgm_dir": "assets/bgm/mood/info",
      "tts_emotion": "neutral"
    },
    "controversy": {
      "label": "논란",
      "intro_image_dir": "assets/image/intro/mood/controversy",
      "outro_image_dir": "assets/image/outro/mood/controversy",
      "bgm_dir": "assets/bgm/mood/controversy",
      "tts_emotion": "serious"
    },
    "daily": {
      "label": "일상",
      "intro_image_dir": "assets/image/intro/mood/daily",
      "outro_image_dir": "assets/image/outro/mood/daily",
      "bgm_dir": "assets/bgm/mood/daily",
      "tts_emotion": "friendly"
    },
    "shock": {
      "label": "충격",
      "intro_image_dir": "assets/image/intro/mood/shock",
      "outro_image_dir": "assets/image/outro/mood/shock",
      "bgm_dir": "assets/bgm/mood/shock",
      "tts_emotion": "surprised"
    }
  },

  "scene_rules": {
    "intro": {
      "description": "제목을 읽어주는 첫 화면",
      "with_image": {
        "layout": "image_text",
        "image_source": "post_images[0]",
        "note": "글에 이미지가 1장 이상이면 첫 번째 이미지 사용"
      },
      "without_image": {
        "layout": "image_only",
        "image_source": "intro_image_dir",
        "note": "글에 이미지가 0장이면 mood별 인트로 폴더에서 랜덤 선택"
      }
    },
    "body": {
      "description": "본문을 읽는 화면들",
      "with_image": { "layout": "image_text" },
      "without_image": { "layout": "text_only" },
      "image_distribution": "even_spread",
      "image_distribution_note": "공식: interval = total_lines / (remaining_images + 1)"
    },
    "outro": {
      "description": "마지막 화면 — 참여 유도형 질문 + 마스코트 + 댓글 입력창 목업 (구독유도 제거)",
      "layout": "outro",
      "fixed_texts": [
        "여러분이라면 어떻게 하셨을까요?",
        "이 상황, 어떻게 생각하시나요?",
        "여러분의 생각을 댓글로 알려주세요!",
        "이게 맞는 행동일까요?",
        "이 이야기, 어떻게 생각하시나요?"
      ],
      "fixed_text_selection": "random",
      "narrate": true,
      "note": "TTS로 질문 문구 내레이션. 마스코트·입력창 목업은 _frames.py 코드 드로잉"
    },
    "chat": {
      "description": "카카오톡 대화 버블 씬 — LLM이 추출한 chat_messages",
      "layout": "chat",
      "enabled": true,
      "max_messages_per_scene": 4,
      "narrate": true,
      "dwell_sec": 3.5,
      "note": "is_mine=true→우측 노란 버블, false→좌측 회색 버블+아바타. 메시지별 TTS 낭독, 화자별 다른 목소리"
    },
    "comments": {
      "description": "실제 커뮤니티 댓글 리스트 화면 — DB 원본 top-N, LLM 우회",
      "layout": "comments",
      "enabled": true,
      "top_n": 5,
      "narrate": true,
      "dwell_sec": 4.0,
      "note": "likes 내림차순 정렬. 1위 is_best=true. 댓글별 TTS 낭독, 작성자별 다른 목소리"
    }
  },

  "defaults": {
    "fallback_mood": "daily",
    "max_body_images": 20,
    "min_body_lines_per_image": 2,
    "supported_image_ext": [".png", ".jpg", ".jpeg", ".webp"],
    "supported_bgm_ext": [".mp3", ".wav", ".ogg"]
  }
}
